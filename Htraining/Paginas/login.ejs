<%- include('../Views/header') %>

<div id="loginPage" class="centered">
    <div class="card-login glass">
        <h2>Htraining</h2>
        <p>Acesse seu painel</p>
        <input type="text" id="username" placeholder="Usuário">
        <input type="password" id="password" placeholder="Senha">
        <button class="btn-primary" style="width: 100%; margin-top: 10px;" onclick="login()">Entrar</button>
        <p id="loginError" style="color: #ff4444; font-size: 12px; margin-top: 10px;"></p>
    </div>
</div>

<%- include('../Views/footer') %>