<%- include('../Views/header') %>

<section id="landingPage" class="landing">
    <header class="landing-header">
        <div class="logo">
            <img src="/IMG/logo.png" alt="Htraining Logo" class="logo-img">
        </div>
        <nav>
            <a href="#sobre">Sobre</a>
            <a href="#funcionalidades">Funcionalidades</a>
            <a href="#planos">Planos</a>
            <button class="btn-entrar" onclick="window.location.href='/login'">Entrar</button>
        </nav>
    </header>

    <div class="hero container">
        <div class="hero-text">
            <h1>Treine <span class="gradient-text">conectado.</span></h1>
            <p>A ponte perfeita entre a gestão do <strong>Personal Trainer</strong> e a evolução real do <strong>Aluno</strong>. Tudo em um só ecossistema.</p>
            <div class="hero-btns">
                <button class="btn-primary" onclick="window.location.href='/login'">Começar agora</button>
                <button class="btn-outline" onclick="window.location.href='#sobre'">Ver como funciona</button>
            </div>
        </div>
        <div class="hero-image">
            <img src="https://images.unsplash.com/photo-1534438327276-14e5300c3a48?auto=format&fit=crop&q=80&w=1000" alt="Treino e Conexão">
        </div>
    </div>

    <div id="sobre" class="container features-grid">
        <div class="feature-main glass">
            <div class="feature-content">
                <span class="badge">Para o Aluno</span>
                <h2>Sua evolução no bolso</h2>
                <p>Agende treinos, visualize sua evolução física e receba orientações do seu personal de forma instantânea.</p>
                <div class="feature-list">
                    <p>✓ Agenda simplificada</p>
                    <p>✓ Gráficos de peso e medidas</p>
                </div>
            </div>
        </div>
        <div class="feature-side glass">
            <span class="badge" style="color: #0ea5e9;">Para o Personal</span>
            <h2>Gestão sem falhas</h2>
            <p>Controle sua agenda de alunos, registre evoluções e profissionalize sua consultoria física.</p>
        </div>
    </div>

    <div id="funcionalidades" class="container icon-features">
        <div class="icon-card glass">
            <div class="icon-circle">📅</div>
            <h3>Agenda Mútua</h3>
            <p style="font-size: 12px; color: #94a3b8; margin-top: 5px;">Aluno agenda, Personal gerencia.</p>
        </div>
        <div class="icon-card glass">
            <div class="icon-circle">📈</div>
            <h3>Evolução Real</h3>
            <p style="font-size: 12px; color: #94a3b8; margin-top: 5px;">Acompanhamento de metas e resultados.</p>
        </div>
        <div class="icon-card glass">
            <div class="icon-circle">💊</div>
            <h3>Dicas e Suporte</h3>
            <p style="font-size: 12px; color: #94a3b8; margin-top: 5px;">Suplementação e orientações integradas.</p>
        </div>
        <div class="icon-card glass">
            <div class="icon-circle">💰</div>
            <h3>Financeiro</h3>
            <p style="font-size: 12px; color: #94a3b8; margin-top: 5px;">Controle de mensalidades e serviços.</p>
        </div>
    </div>

    <div id="planos" class="container pricing-section">
        <div class="pricing-info">
            <h2>O plano ideal para o seu objetivo</h2>
            <p>Seja você um aluno focado ou um treinador em busca de escala.</p>
            <button class="btn-primary" style="margin-top: 20px;">Ver todos os detalhes</button>
        </div>
        
        <div class="pricing-cards-grid">
            <div class="price-card glass">
                <h3>Plano Aluno</h3>
                <div class="price">Grátis</div>
                <ul>
                    <li>✓ Agendar seus treinos</li>
                    <li>✓ Ver sua evolução física</li>
                    <li>✓ Receber notificações</li>
                </ul>
                <button class="btn-card" style="margin-top: auto;" onclick="window.location.href='/login'">Começar Já</button>
            </div>

            <div class="price-card glass highlighted">
                <span class="badge-pro">Autônomo</span>
                <h3>Plano Personal</h3>
                <div class="price">R$ 89,90<span>/mês</span></div>
                <ul>
                    <li>✓ Gerenciar alunos ilimitados</li>
                    <li>✓ Painel administrativo total</li>
                    <li>✓ Relatórios avançados</li>
                    <li>✓ Gestão de pagamentos</li>
                </ul>
                <button class="btn-primary" style="width: 100%; margin-top: auto;" onclick="window.location.href='/login'">Assinar como Personal</button>
            </div>

            <div class="price-card glass highlighted-blue">
                <span class="badge-card blue">Corporativo</span>
                <h3>Gestão Academia</h3>
                <div class="price">R$ 249,90<span>/mês</span></div>
                <ul>
                    <li>✓ Cadastro do perfil da Academia</li>
                    <li>✓ <strong>Limite de até 3 Personais</strong></li>
                    <li>✓ Controle e escala de alunos</li>
                    <li>✓ Monitoramento de avaliações</li>
                </ul>
                <button class="btn-card blue-btn" style="margin-top: auto;" onclick="window.location.href='/login'">Cadastrar Academia</button>
            </div>

            <div class="price-card glass highlighted-green">
                <span class="badge-card green">Equipes</span>
                <h3>Gestão Assessoria</h3>
                <div class="price">R$ 299,90<span>/mês</span></div>
                <ul>
                    <li>✓ Painel para Assessoria de Corrida</li>
                    <li>✓ <strong>Limite de até 3 Personais/Coaches</strong></li>
                    <li>✓ Montagem de planilhas de Pace</li>
                    <li>✓ Análise de performance do grupo</li>
                </ul>
                <button class="btn-card green-btn" style="margin-top: auto;" onclick="window.location.href='/login'">Cadastrar Assessoria</button>
            </div>
        </div>
    </div>
</section>

<%- include('../Views/footer') %>